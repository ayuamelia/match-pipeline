# ── Rate Limiting ─────────────────────────────────────────────────
API_RATE_LIMIT=20/minute

# ── OpenAI (optional) ─────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── CORS ─────────────────────────────────────────────────────────
