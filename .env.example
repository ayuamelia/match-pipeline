# ── Application ──────────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=93e3bf56104b5160ad2ed881e6384538c698b7e89358dd50a19a72900b380110

# ── PostgreSQL ────────────────────────────────────────────────────
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_DB=pelgo
POSTGRES_USER=pelgo
POSTGRES_PASSWORD=pelgo_secret

# asyncpg driver for SQLAlchemy async (API)
DATABASE_URL=postgresql+asyncpg://pelgo:pelgo_secret@db:5432/pelgo

# ── Redis ─────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Candidate ─────────────────────────────────────────────────────
